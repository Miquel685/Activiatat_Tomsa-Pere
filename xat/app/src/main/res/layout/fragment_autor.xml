<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D7DEE6"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:text="Autor:"
        android:textColor="#2C3E50"
        android:textSize="32sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="308dp"
        android:layout_height="124dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="Logo Autor"
        android:src="@drawable/logo_pere_son_gall_header_md"
        app:srcCompat="@drawable/logo_pere_son_gall_header_md"
        tools:srcCompat="@drawable/logo_pere_son_gall_header_md" />

    <ImageView
        android:id="@+id/ivLogo2"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="Logo Autor"
        android:src="@drawable/contacte"
        app:srcCompat="@drawable/contacte"
        tools:srcCompat="@drawable/contacte" />

    <Button
        android:id="@+id/btnExitAutor"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#E67E22"
        android:text="EXIT"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

</LinearLayout>